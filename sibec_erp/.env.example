# Flask runtime
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=false
SECRET_KEY=change-this-secret

# Central database (PostgreSQL)
# Example: postgresql+psycopg2://erp_user:erp_password@192.168.1.10:5432/sibec_erp
DATABASE_URL=postgresql+psycopg2://erp_user:erp_password@localhost:5432/sibec_erp

# Initial admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-admin-password
